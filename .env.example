# Reddit API (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=ai-tool-discovery:v1.0 (by /u/your_username)

# GitHub (Personal Access Token — needs repo:read scope)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic (for Claude Batch extraction)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Supabase (get from Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Apify (for Threads scraping — get token from console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_xxxxxxxx
# 可依買的 actor 調整，預設為官方版
APIFY_THREADS_ACTOR=apify/threads-scraper
